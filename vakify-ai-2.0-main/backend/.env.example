APP_ENV=development
SECRET_KEY=replace-with-strong-random-secret-min-32-chars
JWT_SECRET_KEY=replace-with-strong-random-jwt-secret-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=86400
ADMIN_EMAILS=admin@example.com

# Development default (SQLite). For production use PostgreSQL URL.
DATABASE_URL=sqlite:///adaptive_learning.db
SQLITE_TIMEOUT_SECONDS=30

# CORS: use * in local development, explicit origins in production.
CORS_ORIGINS=*

PORT=5001

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
CLERK_SECRET_KEY=
NVIDIA_IMAGE_API_KEY=
NVIDIA_IMAGE_URL=https://ai.api.nvidia.com/v1/genai/stabilityai/stable-diffusion-3-medium
NVIDIA_IMAGE_CFG_SCALE=5
NVIDIA_IMAGE_ASPECT_RATIO=
NVIDIA_IMAGE_STEPS=50
NVIDIA_IMAGE_SEED=0
NVIDIA_IMAGE_NEGATIVE_PROMPT=

# ElevenLabs TTS (preferred for auditory mode when provided)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Preferred: RapidAPI CodeArena/Judge endpoint.
CODEARENA_BASE_URL=
CODEARENA_API_KEY=
CODEARENA_API_HOST=

# Backward-compatible legacy names.
JUDGE0_BASE_URL=
JUDGE0_API_KEY=
JUDGE0_API_HOST=
